def decode_voynich(text):

    tokens=text.split()

    for t in tokens:

        voynich_memory[t]+=1

    sorted_tokens=sorted(voynich_memory.items(),key=lambda x:x[1],reverse=True)

    return {
        "tokens":tokens,
        "frequency":sorted_tokens[:10]
    }

# ==================================================
# 7. AUTOAPRENDIZAJE
# ==================================================

def learn_pattern(text):

    words=text.split()

    for w in words:

        if w not in knowledge_base:

            knowledge_base[w]=0

        knowledge_base[w]+=1

    return knowledge_base

