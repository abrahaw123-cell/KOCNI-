def fetch_climate_data(lat=22.151, lon=-100.98):

    try:

        url = f"https://api.open-meteo.com/v1/forecast?latitude={lat}&longitude={lon}&current_weather=true"

        r = requests.get(url,timeout=10)

        data = r.json()

        return {
            "temperature": data["current_weather"]["temperature"]
        }

    except:

        return {"temperature": 24}

def fetch_earthquake_data():

    try:

        url="https://earthquake.usgs.gov/fdsnws/event/1/query?format=geojson&limit=5"

        r=requests.get(url)

        data=r.json()

        return len(data["features"])

    except:

        return 0

# ==================================================
# 4. PREDICTOR HAS
# ==================================================

def has_predictor(series,horizon=5):

    data=np.array(series)

    trend=np.polyfit(range(len(data)),data,1)[0]

    forecast=[]

    last=data[-1]

    for i in range(horizon):

        next_val=last+trend+np.sin(i)*0.2

        forecast.append(float(next_val))

        last=next_val

    return forecast

# ==================================================
# 5. VISIÓN ARTIFICIAL
# ==================================================

def analyze_image(path):

    img=cv2.imread(path)

    if img is None:
        return {"error":"imagen no encontrada"}

    gray=cv2.cvtColor(img,cv2.COLOR_BGR2GRAY)

    edges=cv2.Canny(gray,50,150)

    edge_count=int(np.sum(edges>0))

    return {
        "edges":edge_count,
        "shape":img.shape
    }

