def discover_physical_laws(x, y, degree=3):

    x = np.array(x, dtype=float)
    y = np.array(y, dtype=float)

    coef = np.polyfit(x, y, degree)
    predicted = np.polyval(coef, x)

    mse = np.mean((y - predicted)**2)
    r2 = 1 - (mse / np.var(y))

    xs = sp.symbols('x')

    expr = sum(c * xs**i for i, c in enumerate(reversed(coef)))
    simplified = sp.simplify(expr)

    return {
        "equation": str(simplified),
        "coefficients": [float(c) for c in coef],
        "mse": float(mse),
        "r2": float(r2)
    }

# ==================================================
# 2. SIMULADOR FÍSICO
# ==================================================

def simulate_physics(system="pendulum", params=None):

    if params is None:
        params = {}

    if system == "pendulum":

        L = params.get("length", 1)
        g = params.get("g", 9.81)
        theta0 = np.deg2rad(params.get("angle", 30))

        def ode(t, y):

            theta, omega = y
            dtheta = omega
            domega = -(g/L)*np.sin(theta)

            return [dtheta, domega]

        sol = solve_ivp(ode,[0,10],[theta0,0],t_eval=np.linspace(0,10,200))

        period = 2*np.pi*np.sqrt(L/g)

        return {
            "system":"pendulum",
            "period":period,
            "max_angle":float(np.rad2deg(max(sol.y[0])))
        }

    if system == "freefall":

        g = params.get("g",9.81)

        t = np.linspace(0,5,50)

        pos = 0.5*g*t**2

        return {
            "system":"freefall",
            "position":pos.tolist()
        }

