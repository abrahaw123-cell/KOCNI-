def earthquake_monitor():

    url="https://earthquake.usgs.gov/fdsnws/event/1/query"

    params={
        "format":"geojson",
        "limit":5,
        "minmagnitude":4.5
    }

    try:

        r=requests.get(url,params=params,timeout=10)
        data=r.json()

        events=[f["properties"]["mag"] for f in data["features"]]

        return events

    except:
        return []


def climate_monitor():

