class SimpleLearner:

    def __init__(self):

        self.weights=np.random.rand(3)

    def train(self,x,y):

        x=np.array(x)
        y=np.array(y)

        coef=np.polyfit(x,y,1)

        self.weights=coef

    def predict(self,x):

        return self.weights[0]*x+self.weights[1]

learner=SimpleLearner()

