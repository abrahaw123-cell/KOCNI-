# =====================================================
# MOTOR HAS (ANTICIPACIÓN)
# =====================================================

def has_predictor(series,horizon=5):

    data=np.array(series)

    trend=np.polyfit(range(len(data)),data,1)[0]

    forecast=[]
    last=data[-1]

    for i in range(horizon):

        next_val=last+trend+0.2*np.sin(i)

        forecast.append(round(float(next_val),2))

        last=next_val

    return forecast

# =====================================================
# DETECCIÓN DE PATRONES
# =====================================================

def detect_patterns(data):

    data=np.array(data)

    mean=np.mean(data)
    std=np.std(data)

    anomalies=data[np.abs(data-mean)>2*std]

    pattern={
        "mean":float(mean),
        "std":float(std),
        "anomalies":anomalies.tolist()
    }

    memory.store_pattern(pattern)

    return pattern

# =====================================================
# DECODIFICADOR DE ALFABETOS
# =====================================================

def alphabet_decoder(text):

    freq={}

    for c in text:

        if c not in freq:
            freq[c]=0

        freq[c]+=1

    sorted_freq=sorted(freq.items(),key=lambda x:x[1],reverse=True)

    return sorted_freq

# =====================================================
# VISIÓN ARTIFICIAL
# =====================================================

def vision_analyzer(image_path):

    img=cv2.imread(image_path)

    if img is None:
        return {"error":"image not found"}

    gray=cv2.cvtColor(img,cv2.COLOR_BGR2GRAY)

    edges=cv2.Canny(gray,100,200)

    edge_count=np.sum(edges>0)

    return {
        "edges_detected":int(edge_count),
        "resolution":img.shape
    }

