# 4. MODELO PREDICTIVO (aprendizaje online)
# ============================================================================
class ModeloPredictivo:
    def __init__(self):
        self.entrenado = False
        self.pesos = np.array([0.5, 0.5])
        self.hist_kai = deque(maxlen=50)
        self.hist_resp = deque(maxlen=50)

    def entrenar(self, kai, respuesta_real):
        self.hist_kai.append(kai)
        self.hist_resp.append(respuesta_real)
        if len(self.hist_kai) >= 10:
            X = np.array(self.hist_kai).reshape(-1, 1)
            y = np.array(self.hist_resp)
            Xm = np.mean(X)
            ym = np.mean(y)
            num = np.sum((X - Xm) * (y - ym))
            den = np.sum((X - Xm) ** 2)
            if den != 0:
                slope = num / den
                intercept = ym - slope * Xm
                self.pesos = np.array([intercept, slope])
                self.entrenado = True

    def predecir(self, kai):
        if not self.entrenado:
            return 0.5
        return np.clip(self.pesos[0] + self.pesos[1] * kai, 0, 1)

# ============================================================================
# 5. CEREBRO DE ANTICIPACIÓN (KAI, IAO, intervención dinámica)
# ============================================================================
class CerebroAnticipacionIA:
    def __init__(self, config, fase_hemisferica=0.0):
        self.config = config.copy()
        self.theta_base = config["umbral_theta_base"]
        self.alfa = config["alfa_cerebro"]
        self.beta = config["beta_cerebro"]
        self.pesos_kai = config["pesos_kai"].copy()
        self.k_deriv = config["k_derivada_theta"]
        self.hist_kai = deque(maxlen=10)
        self.hist_exp = deque(maxlen=50)
        self.modelo = ModeloPredictivo()
        self.fase_hemisferica = fase_hemisferica

    def calcular_kai(self, c, p, i, e, t):
        senales = np.array([c, p, i, e, t])
        kai = np.dot(self.pesos_kai, senales)
        kai += 0.05 * np.sin(self.fase_hemisferica + time.time())
        return np.clip(kai, 0, 1)

    def evaluar(self, c, p, i, e, t, dt=2.0):
        kai = self.calcular_kai(c, p, i, e, t)
        self.hist_kai.append(kai)
        d_kai = (self.hist_kai[-1] - self.hist_kai[-2]) / dt if len(self.hist_kai) >= 2 else 0.0
        theta_din = np.clip(self.theta_base + self.k_deriv * abs(d_kai), 0.3, 0.9)

        p_resp = self.modelo.predecir(kai)

        haf = (c + p + i) / 3 * (1 - abs(d_kai)) * (0.8 + 0.2 * math.cos(self.fase_hemisferica))
        iao = self.alfa * haf + self.beta * p_resp
        self.hist_exp.append(iao)

        riesgo_ia = 1 - math.exp(-t / (e + 0.1))
        intervencion = iao > theta_din

        self.modelo.entrenar(kai, 1.0 if intervencion else 0.0)

        return {
            "KAI": round(kai, 4),
            "P_Respuesta": round(p_resp, 4),
            "HAF": round(haf, 4),
            "IAO": round(iao, 4),
            "Riesgo_IA": round(riesgo_ia, 4),
            "theta_dinamico": round(theta_din, 4),
            "Intervencion": "⚠️ INTERVENIR" if intervencion else "✅ ESTABLE",
            "dKAI_dt": round(d_kai, 4)
        }

