# 2. ÁNGEL GENESIS (geometría polar basada en números primos)
# ============================================================================
class AngelGenesis:
    def __init__(self, semilla_primo=2):
        self.PHI = PHI
        self.FREQ = 963
        self.primo = semilla_primo

    def generar_espacio_polar(self):
        r = self.primo
        theta = (2 * math.pi * self.primo) / (self.PHI * self.FREQ)
        x = r * math.cos(theta)
        y = r * math.sin(theta)
        return (x, y)

    def activar_vínculo(self, intencion):
        fase = (intencion * self.FREQ) % (self.PHI * 27)
        return fase

