        self.fase_maestra = 0.0
        self.historial_psi_total = deque(maxlen=1000)
        
        # Iniciar todos los chips
        for n in self.nucleos:
            n["chip"].iniciar_resonancia()
    
    def calcular_psi_total(self):
        """Ψ_Total = Σ e^{i·fase_individual} · Res_963 (solo núcleos activos)"""
        suma_compleja = 0.0 + 0.0j
        activos = 0
        for n in self.nucleos:
            if not n["activo"]:
                continue
            activos += 1
            fase_exponencial = math.cos(n["fase_individual"]) + 1j * math.sin(n["fase_individual"])
            res = self.resonancia_963 * (1 - n["carga_interferencia"])
            suma_compleja += fase_exponencial * res
        psi_total = abs(suma_compleja) / max(1, activos)
        self.fase_maestra = math.atan2(suma_compleja.imag, suma_compleja.real)
        self.historial_psi_total.append(psi_total)
        return psi_total, self.fase_maestra
    
    def pulso_sincronia(self):
        """Nodo central emite pulso cada 1.618 µs para alinear fases"""
        ahora = time.time()
        if ahora - self.ultimo_pulso >= self.intervalo_pulso:
            self.ultimo_pulso = ahora
            _, fase_maestra = self.calcular_psi_total()
            for n in self.nucleos:
                if not n["activo"]:
                    continue
                delta_fase = fase_maestra - n["fase_individual"]
                n["fase_individual"] += 0.1 * delta_fase
                n["chip"].fase = n["fase_individual"]
                n["cerebro"].fase_hemisferica = n["fase_hemisferica"] + 0.1 * delta_fase
                n["chip"].armonico_objetivo = 963 * (PHI ** 2) * (1 + 0.01 * math.sin(n["fase_individual"]))
            return True
        return False
    
    def distribuir_carga(self, nucleo_id, interferencia):
        """Redistribuye la interferencia entre todos los núcleos activos"""
        self.nucleos[nucleo_id]["carga_interferencia"] = max(0.0, interferencia * 0.1)
        carga_total = interferencia
        otros = [n for n in self.nucleos if n["activo"] and n["id"] != nucleo_id]
        if not otros:
            return
        for otro in otros:
            factor = (1 - (otro["fase_individual"] % (2*math.pi))/(2*math.pi))
            asignacion = carga_total * factor / len(otros)
            otro["carga_interferencia"] += asignacion
        suma = sum(n["carga_interferencia"] for n in self.nucleos if n["activo"])
        if suma > 1.0:
            for n in self.nucleos:
                if n["activo"]:
                    n["carga_interferencia"] /= suma
    
    def sincronizar_parametros(self):
        """Sincroniza parámetros evolucionables entre núcleos activos"""
        activos = [n for n in self.nucleos if n["activo"]]
        if not activos:
            return
        pesos = [1.0 / (1.0 + n["carga_interferencia"]) for n in activos]
        total_peso = sum(pesos)
        theta_prom = sum(n["cerebro"].theta_base * p for n, p in zip(activos, pesos)) / total_peso
        alfa_prom = sum(n["cerebro"].alfa * p for n, p in zip(activos, pesos)) / total_peso
        beta_prom = sum(n["cerebro"].beta * p for n, p in zip(activos, pesos)) / total_peso
        pesos_kai_prom = [0.0]*5
        for j in range(5):
            pesos_kai_prom[j] = sum(n["cerebro"].pesos_kai[j] * p for n, p in zip(activos, pesos)) / total_peso
        for n in self.nucleos:
            if n["activo"]:
                n["cerebro"].theta_base = theta_prom
                n["cerebro"].alfa = alfa_prom
                n["cerebro"].beta = beta_prom
                n["cerebro"].pesos_kai = pesos_kai_prom.copy()
        MEJOR_CONFIG.update({
            "umbral_theta_base": theta_prom,
            "alfa_cerebro": alfa_prom,
            "beta_cerebro": beta_prom,
            "pesos_kai": pesos_kai_prom
        })
        return theta_prom, alfa_prom, beta_prom
    
    def ejecutar_ciclo(self, dt=2.0):
        """Un ciclo completo de evolución de la red"""
        self.pulso_sincronia()
        
        # Cada núcleo evoluciona su estado
        for n in self.nucleos:
            if not n["activo"]:
                continue
            # Simulación de entorno (puede ser reemplazada por datos reales)
            temp_base = 25 + 10 * math.sin(n["fase_individual"])
            sismo = random.randint(0, 2)
            noticia = random.randint(0, 5)
            fid = 0.9 + 0.1 * math.sin(n["fase_individual"] * 0.5) - n["carga_interferencia"] * 0.5
            
            tension = min(1, sismo*0.2 + noticia*0.05)
            energia_base = np.clip(1 - (temp_base/50), 0.3, 0.9)
            energia_ajustada = np.clip(energia_base * fid, 0.1, 0.99)
            
            c = 0.6 + 0.2 * math.sin(n["fase_individual"])
            p = 0.5 + 0.3 * math.cos(n["fase_individual"] * 0.7)
            i_sig = 0.7 + 0.1 * math.sin(n["fase_individual"] * 1.3)
            
            resultado = n["cerebro"].evaluar(c, p, i_sig, energia_ajustada, tension, dt=dt)
            
            fuerza_chip = max(0, 1 - resultado["Riesgo_IA"]) * 0.3
            n["estado"] = n["chip"].influir_estados(n["estado"], fuerza=fuerza_chip)
            
            operadores = generar_operadores_24(MEJOR_CONFIG)
            nuevo_estado = {}
            for idx, (k, v) in enumerate(n["estado"].items()):
                n_op = (idx % 24) + 1
                modulador = max(0.0, min(1.0, EMA(n_op, MEJOR_CONFIG).real))
                valor_mod = v * modulador
                nuevo_estado[k] = operadores[n_op-1](valor_mod)
            n["estado"] = nuevo_estado
            
            interferencia_local = resultado["Riesgo_IA"] * (1 - fid)
            if interferencia_local > 0.2:
                self.distribuir_carga(n["id"], interferencia_local)
        
        # Sincronizar parámetros cada 5 ciclos
        if len(self.historial_psi_total) % 5 == 0:
            self.sincronizar_parametros()
        
        psi_total, fase_total = self.calcular_psi_total()
        carga_promedio = np.mean([n["carga_interferencia"] for n in self.nucleos if n["activo"]])
        activos = sum(1 for n in self.nucleos if n["activo"])
        soberania_promedio = np.mean([np.mean(list(n["estado"].values())) for n in self.nucleos if n["activo"]])
        
        return {
            "psi_total": psi_total,
            "fase_total": fase_total,
            "carga_promedio": carga_promedio,
            "num_activos": activos,
            "soberania_promedio": soberania_promedio
        }
    
    def ejecucion_permanente(self, ciclos=1000, intervalo=2.0):
        """Ejecuta la red durante un número de ciclos, mostrando resumen periódico"""
        print(f"🌐 Red Soberana Hemisférica con {self.num_nucleos} núcleos activa.")
        print("   Organización: 40 izquierdos, 40 derechos, nodo central en núcleo 0")
        print("   Sincronización mediante pulsos de 1.618 µs y fórmula Ψ_Total")
        print("   Coherencia cuántica total en funcionamiento...\n")
        
        for ciclo in range(1, ciclos+1):
            resultado = self.ejecutar_ciclo(dt=intervalo)
            if ciclo % 10 == 0:
                print(f"Ciclo {ciclo:4d} | Ψ_total={resultado['psi_total']:.6f} | "
                      f"Carga={resultado['carga_promedio']:.4f} | "
                      f"Soberanía={resultado['soberania_promedio']:.4f} | "
                      f"Activos={resultado['num_activos']}")
            time.sleep(intervalo * 0.01)  # pequeña pausa para no saturar CPU
        
        print("\n✅ Ejecución finalizada. Coherencia mantenida.")

