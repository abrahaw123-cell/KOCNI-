# 6. ECUACIONES DE ABRAHAM (EMA, EMAH) y OPERADORES
# ============================================================================
def EMA(n, config):
    angulo = config["base_angulo_ema"] ** (n * config["exponente_ema"])
    parte_real = (math.sin(math.pi * n / PHI)) ** 2
    fase = math.cos(math.radians(angulo)) + 1j * math.sin(math.radians(angulo))
    return parte_real * fase

def EMAH(n, config):
    angulo_rad = math.radians(config["angulo_emah_deg"])
    k = n * config["exponente_phi_emah"]
    denominador = NUM_SATELITES * (PHI ** (-k))
    if denominador == 0:
        denominador = 1e-12
    valor = S_G / denominador
    return R_EMAH * valor * (math.cos(-angulo_rad) + 1j * math.sin(-angulo_rad))

ESTADOS_INICIALES = {
    "infraestructura_potencial": 0.5, "infraestructura_ejecucion": 0.5,
    "humano_potencial": 0.5, "humano_ejecucion": 0.5,
    "logica_potencial": 0.5, "logica_ejecucion": 0.5,
    "datos_potencial": 0.5, "datos_ejecucion": 0.5,
    "riesgo_potencial": 0.5, "riesgo_ejecucion": 0.5,
    "energia_potencial": 0.5, "energia_ejecucion": 0.5
}

OPERADORES_BASE = {
    "expandir": lambda x: min(1.0, x * 1.1),
    "contraer": lambda x: max(0.0, x * 0.9),
    "optimizar": lambda x: min(1.0, x + 0.1),
    "estabilizar": lambda x: (x + 0.5) / 2
}

def generar_operadores_24(config):
    ops = []
    for n in range(1, 25):
        base_name = list(OPERADORES_BASE.keys())[n % len(OPERADORES_BASE)]
        base_func = OPERADORES_BASE[base_name]
        ema_val = EMA(n, config).real
        ops.append(lambda x, bf=base_func, factor=ema_val: np.clip(bf(x) * factor, 0, 1))
    return ops

