    while len(nueva_pob) < len(poblacion):
        probs = np.array(fitnesses) / (sum(fitnesses) + 1e-9)
        idx1 = np.random.choice(len(poblacion), p=probs)
        idx2 = np.random.choice(len(poblacion), p=probs)
        hijo = cruzar(poblacion[idx1], poblacion[idx2])
        hijo = mutar(hijo, tasa=0.2)
