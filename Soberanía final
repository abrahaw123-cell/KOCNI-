def butter_bandpass(lowcut, highcut, fs, order=4):
    nyq = 0.5*fs
    low = lowcut/nyq
    high = highcut/nyq
    b, a = butter(order, [low, high], btype='band')
    return b, a

def apply_bandpass(data, lowcut, highcut, fs=1.0):
    if len(data) < 6:
        return data
    b, a = butter_bandpass(lowcut, highcut, fs, order=2)
    return lfilter(b, a, data)

