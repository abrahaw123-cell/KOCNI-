def mutar(config, tasa=0.1):
    nuevo = config.copy()
    for key in nuevo:
        if np.random.rand() < tasa:
            if isinstance(nuevo[key], float):
                nuevo[key] += np.random.normal(0, 0.05 * abs(nuevo[key]))
                if "angulo" in key:
                    nuevo[key] = np.clip(nuevo[key], 0, 360)
                elif "exponente" in key:
                    nuevo[key] = np.clip(nuevo[key], 0.5, 2.0)
                elif "umbral" in key or "alfa" in key or "beta" in key:
                    nuevo[key] = np.clip(nuevo[key], 0.1, 0.9)
                elif "ganancia" in key:
                    nuevo[key] = np.clip(nuevo[key], 0.5, 2.0)
            elif isinstance(nuevo[key], list):
                nuevo[key] = np.clip(np.array(nuevo[key]) + np.random.normal(0, 0.05, len(nuevo[key])), 0, 1).tolist()
                s = sum(nuevo[key])
                if s > 0:
                    nuevo[key] = [x / s for x in nuevo[key]]
    return nuevo

def cruzar(padre, madre):
    hijo = {}
    for key in padre:
        hijo[key] = padre[key] if np.random.rand() < 0.5 else madre[key]
    return hijo

