# 6. ECUACIONES DE ABRAHAM (EMA, EMAH)
# ============================================================================
def EMA(n, config):
    angulo = config["base_angulo_ema"] ** (n * config["exponente_ema"])
    parte_real = (np.sin(pi * n / PHI)) ** 2
    fase = np.exp(1j * np.radians(angulo))
    return parte_real * fase

def EMAH(n, config):
    angulo_rad = np.radians(config["angulo_emah_deg"])
    k = n * config["exponente_phi_emah"]
    denominador = NUM_SATELITES * (PHI ** (-k))
    if denominador == 0:
        denominador = 1e-12
    valor = S_G / denominador
    return R_EMAH * valor * np.exp(-1j * angulo_rad)

