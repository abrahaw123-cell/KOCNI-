# 8. MÉTRICAS DE ABRAHAM Y NUEVAS (K_R, potencia, entropía)
# ============================================================================
def calcular_soberania_Sd(V_p, R_h, A_i):
    return (V_p * R_h) / (A_i + 1e-6)

def calcular_blindaje_Ip(ping_hostil, psi_A):
    return ping_hostil / (abs(psi_A) + 1e-6)

def calcular_fuerza_vigilancia_Fv(G_a, m1, m2, r):
    return G_a * (m1 * m2) / (r**6 + 1e-6)

def calcular_topologia_chi(estados):
    varianza = np.var(list(estados.values()))
    return 2.0 if varianza < 0.1 else 0.0

def funcion_onda_psi(t, omega, phi, psi0=1.0):
    return psi0 * np.cos(omega * t + phi)

def calcular_potencia_sintonizada(fase, amplitud, ganancia=1.0):
    return ganancia * abs(fase) * amplitud

def calcular_entropia(estados):
    valores = np.array(list(estados.values()))
    if np.sum(valores) == 0:
        return 0
    p = valores / (np.sum(valores) + 1e-9)
    return -np.sum(p * np.log(p + 1e-9))

def calcular_coeficiente_resonancia(info_procesada, agua_consumida, energia_consumida):
    denominador = agua_consumida + energia_consumida + 1e-9
    return info_procesada / denominador

