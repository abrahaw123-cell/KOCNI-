class ESAEngine:
    def __init__(self):
        self.PHI = (1 + 5**0.5) / 2
        self.M53 = 142370057
        
    def get_phase_coherence(self, value):
        """Calcula qué tan cerca está un dato de la Singularidad."""
        # Aplicamos la EMA-Inv (Retro-sintonía)
        phase = np.exp(-1j * np.pi * (value % 100) / self.PHI)
        resonance = np.real(phase * self.PHI)
        # Distancia a la singularidad del M53
        dist = np.abs(resonance - (self.M53 % self.PHI))
        return 1 / (1 + dist)

