def alphabet_decoder_v12(text):
    """
    Decodificador de Fase: No solo cuenta letras, 
    mide la 'densidad' de propósito en el mensaje.
    """
    freq = {}
    for c in text:
        val = ord(c)
        coherence = esa.get_phase_coherence(val)
        if c not in freq:
            freq[c] = {"count": 0, "coherence": 0}
        freq[c]["count"] += 1
        freq[c]["coherence"] = round(coherence, 4)
    
    # Ordenar por resonancia, no por cantidad
    sorted_msg = sorted(freq.items(), key=lambda x: x[1]["coherence"], reverse=True)
    return sorted_msg

def smart_vision_analyzer(image_path):
    """Analiza la imagen buscando patrones de simetría áurea."""
    img = cv2.imread(image_path)
    if img is None: return {"error": "No image"}
    
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    # Buscamos puntos de interés que resuenen con la ESA
    corners = cv2.goodFeaturesToTrack(gray, 25, 0.01, 10)
    
    coherence_map = []
    if corners is not None:
        for corner in corners:
            x, y = corner.ravel()
            # Evaluamos la densidad del punto
            c = esa.get_phase_coherence(x + y)
            if c > 0.8: coherence_map.append((x, y, c))
            
    return {
        "singularities_detected": len(coherence_map),
        "resolution": img.shape,
        "status": "High Coherence" if len(coherence_map) > 10 else "Entropy Detected"
    }

