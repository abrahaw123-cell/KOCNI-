# 5. MOTOR HAS (ANTICIPACIÓN)
# =====================================================

def has_predictor(series,horizon=5):

    data=np.array(series,dtype=float)

    trend=np.polyfit(range(len(data)),data,1)[0]

    forecast=[]
    last=data[-1]

    for i in range(horizon):

        next_val=last+trend+0.2*np.sin(i)

        forecast.append(round(float(next_val),2))

        last=next_val

    return {
        "trend":round(float(trend),4),
        "forecast":forecast
    }


# =====================================================
# 6. MOTOR DE PATRONES
# =====================================================

def detect_patterns(data):

    data=np.array(data)

    mean=np.mean(data)
    std=np.std(data)

    anomalies=data[np.abs(data-mean)>2*std]

    return {
        "mean":round(float(mean),3),
        "std":round(float(std),3),
        "anomalies":anomalies.tolist()
    }


