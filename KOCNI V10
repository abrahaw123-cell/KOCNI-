def fetch_climate_data(lat=22.151,lon=-100.98):

    url=f"https://api.open-meteo.com/v1/forecast?latitude={lat}&longitude={lon}&current_weather=true"

    try:

        r=requests.get(url,timeout=10)
        data=r.json()

        temp=data["current_weather"]["temperature"]

        return {
            "temperature":temp,
            "summary":f"Temperatura actual: {temp}°C"
        }

    except:

        return {
            "temperature":24,
            "summary":"dato simulado"
        }


