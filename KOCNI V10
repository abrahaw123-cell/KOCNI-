# 1. MOTOR DE DESCUBRIMIENTO DE LEYES (AI Feynman lite)
# =====================================================

def discover_physical_laws(x, y, max_degree=4):

    x = np.array(x, dtype=float)
    y = np.array(y, dtype=float)

    coef = np.polyfit(x, y, max_degree)
    predicted = np.polyval(coef, x)

    mse = float(np.mean((y - predicted)**2))
    r2 = 1 - (mse / np.var(y)) if np.var(y) > 1e-8 else 1.0

    xs = sp.symbols('x')
    expr = sum(c * xs**i for i, c in enumerate(reversed(coef)))
    simplified = sp.simplify(expr)

    return {
        "equation": str(simplified),
        "coefficients": coef.tolist(),
        "mse": round(mse,6),
        "r2": round(r2,4)
    }


# =====================================================
# 2. SIMULADOR FÍSICO
# =====================================================

def simulate_physics(system="pendulum", params=None, t_max=10):

    if params is None:
        params = {}

    t = np.linspace(0, t_max, 500)

    if system == "pendulum":

        L = params.get("length",1.0)
        g = params.get("g",9.81)
        theta0 = np.deg2rad(params.get("initial_angle",30))

        def ode(t,y):
            theta,omega = y
            dtheta = omega
            domega = -(g/L)*np.sin(theta)
            return [dtheta,domega]

        sol = solve_ivp(ode,[0,t_max],[theta0,0],t_eval=t)

        period = 2*np.pi*np.sqrt(L/g)

        return {
            "system":"pendulum",
            "period":round(period,3),
            "theta":sol.y[0].tolist()
        }

    if system == "freefall":

        g = params.get("g",9.81)

        pos = 0.5*g*t**2
        vel = g*t

        return {
            "system":"freefall",
            "position":pos.tolist(),
            "velocity":vel.tolist()
        }

    return {"error":"unknown system"}


# =====================================================
# 3. DATOS REALES (TIERRA)
# =====================================================

def fetch_earthquake_data(limit=10):

    url="https://earthquake.usgs.gov/fdsnws/event/1/query"

    params={
        "format":"geojson",
        "limit":limit,
        "minmagnitude":4.5,
        "orderby":"time"
    }

    try:

        r=requests.get(url,params=params,timeout=10)
        data=r.json()

        events=[]

        for f in data["features"]:

            events.append({
                "mag":f["properties"]["mag"],
                "place":f["properties"]["place"]
            })

        return {"events":events,"count":len(events)}

    except:
        return {"events":[],"count":0}


